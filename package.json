{
  "name": "@ladamczyk/qoq",
  "version": "4.3.4",
  "private": true,
  "bugs": {
    "url": "https://github.com/ladamczyk-it/qoq/issues"
  },
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "lerna run build",
    "check:engine": "check-engine",
    "config-inspector": "node ./scripts/config-inspector.js",
    "config-inspector:clean": "rimraf -g ./packages/eslint-v9-*/stats/",
    "husky:pre-push": "run-s build check:engine typecheck test qoq:check",
    "postinstall": "qoq --warmup",
    "pre:test": "npm run config-inspector",
    "prepare": "husky",
    "publish:full": "run-s husky:pre-push publish:release",
    "publish:release": "npx --package semantic-release --package @semantic-release/changelog --package @semantic-release/git --package semantic-release-lerna -y semantic-release",
    "qoq:check": "qoq --check",
    "qoq:fix": "qoq --fix",
    "sort:packages:json": "npx -y sort-package-json 'package.json' 'packages/*/package.json'",
    "test": "npm run pre:test && vitest run",
    "test:coverage": "npm run pre:test && npm run test -- --coverage",
    "test:execute": "vitest run",
    "typecheck": "lerna run typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@ladamczyk/check-engine": "latest",
    "@ladamczyk/qoq-cli": "latest",
    "@ladamczyk/qoq-eslint-v9-ts": "latest",
    "@ladamczyk/qoq-eslint-v9-ts-jest": "latest",
    "@ladamczyk/qoq-jscpd": "latest",
    "@ladamczyk/qoq-knip": "latest",
    "@ladamczyk/qoq-prettier-with-json-sort": "latest",
    "@ladamczyk/skillslint": "4.0.8",
    "@types/node": "^22",
    "@vitest/coverage-v8": "4.1.9",
    "dotenv": "17.4.2",
    "husky": "9.1.7",
    "lerna": "9.0.7",
    "npm-run-all": "4.1.5",
    "rimraf": "6.1.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22.15.0"
  }
}
