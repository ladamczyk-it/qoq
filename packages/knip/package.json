{
  "name": "@ladamczyk/qoq-knip",
  "version": "5.0.0",
  "description": "Knip configs template",
  "keywords": [
    "Knip template",
    "ladamczyk",
    "qoq",
    "QualityOverQuantity"
  ],
  "homepage": "https://github.com/ladamczyk-it/qoq/tree/master/packages/knip",
  "bugs": {
    "url": "https://github.com/ladamczyk-it/qoq/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ladamczyk-it/qoq.git",
    "directory": "packages/knip"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./lib/src/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    },
    "./knipConfig": {
      "types": "./lib/knipConfig.d.ts",
      "module": "./lib/knipConfig.mjs",
      "import": "./lib/knipConfig.mjs",
      "require": "./lib/knipConfig.cjs",
      "default": "./lib/knipConfig.mjs"
    }
  },
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/src/index.d.ts",
  "files": [
    "lib",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "rimraf ./lib && rollup -c --silent",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "knip": "6.24.0"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "12.3.0",
    "rimraf": "6.1.3",
    "rollup": "4.62.2",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "4c369fd421f71f58eb1d8467eaa02d85d2f09263"
}
