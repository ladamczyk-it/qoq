{
  "name": "@ladamczyk/qoq-eslint-v9-js-jest",
  "version": "4.2.3",
  "description": "Eslint flat config template for JS + Jest",
  "keywords": [
    "eslint JavaScript + Jest template",
    "flat config",
    "ladamczyk",
    "qoq",
    "QualityOverQuantity"
  ],
  "homepage": "https://github.com/ladamczyk-it/qoq/tree/master/packages/eslint-v9-js-jest",
  "bugs": {
    "url": "https://github.com/ladamczyk-it/qoq/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/ladamczyk-it/qoq.git",
    "directory": "packages/eslint-v9-js-jest"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./lib/src/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    }
  },
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/src/index.d.ts",
  "bin": {
    "@ladamczyk/qoq-eslint-v9-js-jest": "./bin/bin.js"
  },
  "files": [
    "bin",
    "lib",
    "eslint.config.local.js",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "rimraf ./lib && rollup -c rollup.config.js --silent && rimraf ./bin && rollup -c rollup.bin.js --silent",
    "inspect": "node ./bin/bin.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ladamczyk/qoq-eslint-v9-js": "^4.2.3",
    "@ladamczyk/qoq-utils": "^4.2.3",
    "eslint-plugin-jest": "29.15.2",
    "globals": "17.6.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "rimraf": "6.1.3",
    "rollup": "4.62.0",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "eslint": "^10.3.0"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "4c369fd421f71f58eb1d8467eaa02d85d2f09263"
}
